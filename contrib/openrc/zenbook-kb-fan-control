#!/sbin/openrc-run
# Adaptive fan profile daemon (kb-fan-control).
#
# Machine-global config (not per-user):
#   cp /usr/share/zenbook-scripts/fan-control.json.example \
#      /etc/zenbook-scripts/fan-control.json
#   sudo rc-update add zenbook-kb-fan-control default
#   sudo rc-service zenbook-kb-fan-control start
#
# Override path with FAN_CONTROL_CONFIG in /etc/conf.d/zenbook-kb-fan-control.

name="zenbook-kb-fan-control"
description="Zenbook adaptive fan profile controller"

: "${command:=/usr/local/bin/kb-fan-control}"
: "${command_args:=run}"
: "${command_background:=yes}"
: "${pidfile:=/run/${RC_SVCNAME}.pid}"
: "${output_log:=/var/log/${RC_SVCNAME}.log}"
: "${error_log:=/var/log/${RC_SVCNAME}.log}"
: "${FAN_CONTROL_CONFIG:=/etc/zenbook-scripts/fan-control.json}"

depend() {
	need localmount
	use logger
	after modules
}

start_pre() {
	if [ ! -x "${command}" ]; then
		if [ -x /usr/bin/kb-fan-control ]; then
			command=/usr/bin/kb-fan-control
		else
			eerror "kb-fan-control not found"
			return 1
		fi
	fi
	cfg="${FAN_CONTROL_CONFIG}"
	if [ ! -f "${cfg}" ]; then
		ewarn "missing ${cfg}"
		ewarn "copy fan-control.json.example → /etc/zenbook-scripts/fan-control.json"
	fi
	command_args="run -c ${cfg}"
	if [ -n "${output_log:-}" ]; then
		checkpath -f -m 0644 -o root:root "${output_log}"
	fi
}
