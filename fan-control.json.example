{
  "daemon": {
    "interval_sec": 5,
    "hysteresis_sec": 30,
    "watch_lid": true,
    "watch_power": true,
    "rules_while_lid_closed": false
  },
  "profiles": {
    "powersave": {
      "platform_profile": "quiet",
      "pwm": "auto",
      "epp": "power",
      "intel_pstate": { "max_perf_pct": 60, "no_turbo": false },
      "rapl": { "pl1_w": 15, "pl2_w": 28 }
    },
    "balanced": {
      "platform_profile": "balanced",
      "pwm": "auto",
      "epp": "balance_performance",
      "intel_pstate": { "max_perf_pct": 100, "no_turbo": false },
      "rapl": { "pl1_w": 28, "pl2_w": 45 }
    },
    "performance": {
      "platform_profile": "performance",
      "pwm": "auto",
      "epp": "performance",
      "intel_pstate": { "max_perf_pct": 100, "no_turbo": false },
      "rapl": { "pl1_w": 45, "pl2_w": 64 }
    },
    "full": {
      "platform_profile": "performance",
      "pwm": "full",
      "epp": "performance",
      "intel_pstate": { "max_perf_pct": 100, "no_turbo": false }
    }
  },
  "rules": {
    "ac": [
      { "when": { "load_lt": 15 }, "profile": "powersave" },
      { "when": { "load_gte": 15, "load_lt": 85 }, "profile": "balanced" },
      { "when": { "load_gte": 85 }, "profile": "performance" }
    ],
    "battery": [
      { "when": { "temp_lt": 65, "load_lt": 40 }, "profile": "powersave" },
      { "when": { "temp_lt": 80 }, "profile": "balanced" },
      { "when": { "temp_gte": 80 }, "profile": "performance" }
    ]
  },
  "events": {
    "lid_close": {
      "profile": "powersave"
    },
    "lid_open": {
      "profile": null
    },
    "sleep_pre": {
      "profile": "powersave"
    },
    "sleep_post": {
      "profile": null
    },
    "ac_online": {
      "profile": null
    },
    "ac_offline": {
      "profile": "powersave"
    },
    "ac_change": {
      "profile": null
    }
  }
}
