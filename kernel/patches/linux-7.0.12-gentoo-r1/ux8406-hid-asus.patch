+#define ZENBOOK_HID_F1		0x3a
+#define ZENBOOK_HID_F12		0x45
+#define ZENBOOK_HID_ESC		0x29
+#define ZENBOOK_IF0_MOD_GUI	(BIT(3) | BIT(7))
