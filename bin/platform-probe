#!/usr/bin/env python3
"""Probe laptop platform features (dry-run / emerge helper).

Vendor-agnostic where possible: reports what this kernel exposes for fans,
platform_profile, CPU power, backlight, touchpad, etc. Does not change state.

Examples:
  platform-probe
  platform-probe --json
  platform-probe --feature fan_pwm
  platform-probe --recommend-use
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

# Allow running from a git checkout or after install under /usr{/local}/share.
_ROOT = Path(__file__).resolve().parent.parent
_SHARE_CANDIDATES = (
    _ROOT,
    Path("/usr/local/share/zenbook-scripts"),
    Path("/usr/share/zenbook-scripts"),
)
for _share in _SHARE_CANDIDATES:
    if (_share / "zenbook_kb").is_dir() and str(_share) not in sys.path:
        sys.path.insert(0, str(_share))
        break

from zenbook_kb.platform.capabilities import (  # noqa: E402
    build_report,
    format_report_json,
    format_report_text,
)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--json",
        action="store_true",
        help="machine-readable JSON (emerge / scripts)",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="alias for default probe (no sysfs writes)",
    )
    parser.add_argument(
        "--feature",
        metavar="ID",
        help="exit 0 if feature supported, 1 otherwise (e.g. fan_pwm, platform_profile)",
    )
    parser.add_argument(
        "--recommend-use",
        action="store_true",
        help="print suggested Gentoo USE flags only",
    )
    parser.add_argument(
        "-q",
        "--quiet",
        action="store_true",
        help="less detail",
    )
    args = parser.parse_args(argv)

    report = build_report()

    if args.feature:
        feat = report.by_id(args.feature)
        if feat is None:
            print(f"unknown feature id: {args.feature}", file=sys.stderr)
            print(
                "known:",
                ", ".join(f.id for f in report.features),
                file=sys.stderr,
            )
            return 2
        if not args.quiet:
            print(f"{feat.id}: {'supported' if feat.supported else 'unsupported'} — {feat.detail}")
        return 0 if feat.supported else 1

    if args.recommend_use:
        parts = list(report.recommend_use)
        parts.extend(f"-{u}" for u in report.recommend_skip_use)
        print(" ".join(parts))
        return 0

    if args.json:
        print(format_report_json(report))
    else:
        print(format_report_text(report, verbose=not args.quiet))
        print()
        print("This is a dry probe — no settings were changed.")
        print("CLIs: platform-fan, platform-fan-control, kb-brightness, kb-platform-profile")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
