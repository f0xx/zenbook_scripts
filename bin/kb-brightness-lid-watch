#!/usr/bin/env bash
# Watch logind/elogind LidClosed and dim/restore Zenbook keyboard backlight.
# acpid lid events are not delivered when elogind owns the lid switch.

set -euo pipefail

PIDFILE="${ZENBOOK_LID_PIDFILE:-/run/zenbook-kb-lid.pid}"

_zenbook_clear_stale_pidfile() {
	local pf="$1" pid=""
	[[ -f "${pf}" ]] || return 0
	pid="$(tr -d '[:space:]' < "${pf}" 2>/dev/null || true)"
	if [[ -z "${pid}" ]] || ! kill -0 "${pid}" 2>/dev/null; then
		rm -f "${pf}"
	fi
}

_zenbook_clear_stale_pidfile "${PIDFILE}"
if [[ -f "${PIDFILE}" ]]; then
	echo "lid-watch already running (pid $(cat "${PIDFILE}"), ${PIDFILE}); remove pidfile or stop the service" >&2
	exit 1
fi
echo $$ >"${PIDFILE}"
trap 'rm -f "${PIDFILE}"' EXIT INT TERM HUP

zenbook_kb_run_user() {
	if [[ -r /etc/conf.d/zenbook-kb-hotkeys ]]; then
		grep -E '^command_user=' /etc/conf.d/zenbook-kb-hotkeys 2>/dev/null \
			| head -1 \
			| sed 's/^command_user=//' \
			| tr -d '"' \
			| cut -d: -f1
	fi
}

USER="$(zenbook_kb_run_user)"
if [[ -n "${USER}" && "${USER}" != root ]]; then
	export ZENBOOK_CALIB_USER="${USER}"
fi

SLEEP_BIN="${KB_BRIGHTNESS_SLEEP_BIN:-/usr/bin/kb-brightness-sleep}"
if [[ ! -x "${SLEEP_BIN}" ]]; then
	SLEEP_BIN="/usr/local/bin/kb-brightness-sleep"
fi
BUS=org.freedesktop.login1
PATH_OBJ=/org/freedesktop/login1
IFACE=org.freedesktop.login1.Manager
PROP=LidClosed

_lid_closed() {
	busctl get-property "${BUS}" "${PATH_OBJ}" "${IFACE}" "${PROP}" 2>/dev/null \
		| awk '{print $2}'
}

_apply() {
	local state="$1"
	case "${state}" in
		true)  "${SLEEP_BIN}" lid-close ;;
		false) "${SLEEP_BIN}" lid-open ;;
	esac
}

if ! busctl status "${BUS}" >/dev/null 2>&1; then
	echo "logind (${BUS}) not available" >&2
	exit 1
fi

last="$(_lid_closed)"
logger -t zenbook-kb-brightness "lid-watch: started (LidClosed=${last} pidfile=${PIDFILE})"

while true; do
	sleep 0.4
	current="$(_lid_closed)" || continue
	if [[ "${current}" == "${last}" ]]; then
		continue
	fi
	if _apply "${current}"; then
		logger -t zenbook-kb-brightness "lid-watch: LidClosed=${current}"
	else
		logger -t zenbook-kb-brightness "lid-watch: action failed for LidClosed=${current}"
	fi
	last="${current}"
done
