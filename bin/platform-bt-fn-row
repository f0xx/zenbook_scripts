    KEY_KBDILLUMTOGGLE: "KBDILLUM",
    KEY_BRIGHTNESSDOWN: "BRTDOWN",
    KEY_BRIGHTNESSUP: "BRTUP",
    KEY_MICMUTE: "MICMUTE",
