    0x88: KEY_F10,
    0x7E: KEY_F11,
    0x86: KEY_F12,
    0x76: KEY_F12,
}
VENDOR_ROW_CODES = frozenset(VENDOR_PLAIN_TO_FKEY) - {0x76}

SWAP: dict[int, int] = {
    KEY_MUTE: KEY_F1,
    KEY_F1: KEY_MUTE,
    KEY_VOLUMEDOWN: KEY_F2,
    KEY_F2: KEY_VOLUMEDOWN,
    KEY_VOLUMEUP: KEY_F3,
    KEY_F3: KEY_VOLUMEUP,
    KEY_KBDILLUMTOGGLE: KEY_F4,
    KEY_F4: KEY_KBDILLUMTOGGLE,
    KEY_BRIGHTNESSDOWN: KEY_F5,
    KEY_F5: KEY_BRIGHTNESSDOWN,
    KEY_BRIGHTNESSUP: KEY_F6,
    KEY_F6: KEY_BRIGHTNESSUP,
    KEY_SWITCHVIDEOMODE: KEY_F7,
    KEY_MICMUTE: KEY_F9,
    KEY_F9: KEY_MICMUTE,
    KEY_RFKILL: KEY_F10,
    KEY_F10: KEY_RFKILL,
    KEY_EMOJI_PICKER: KEY_F11,
    KEY_F11: KEY_EMOJI_PICKER,
