#!/usr/bin/env python3
"""Invert Primax UX8406 Bluetooth Mode B Fn-row toward docked fn_row_policy=7.

Firmware Mode B (BT): plain F → special/media, Fn+F → KEY_F*
Docked policy=7:       plain F → KEY_F*,         Fn+F → special/media

Safety model
------------
EVIOCGRAB silences the physical keyboard. If our uinput is not yet accepted by
the session, **every key dies** (Enter included). Flushing uinput keys cannot
fix that — only **ungrab** (stop) restores typing.

So we:
  1. Create uinput and wait until it has ID_INPUT_KEYBOARD in sysfs
  2. Grab only after that, and verify the grab is exclusive
  3. Never blast 1..255 key-ups (that confused sessions before)
  4. ``stop`` / ``panic`` always ungrab — use the STOP desktop icon if Enter is dead

Usage:
  sudo platform-bt-fn-row start
  sudo platform-bt-fn-row stop     # ungrab — restores physical keyboard
  sudo platform-bt-fn-row panic    # alias for stop (mouse / SSH emergency)
  sudo platform-bt-fn-row run
  platform-bt-fn-row status
  platform-bt-fn-row list
"""

from __future__ import annotations

import argparse
import atexit
import errno
import os
import select
import shutil
import signal
import struct
import subprocess
import sys
import time
from pathlib import Path

EV_KEY = 0x01
EV_SYN = 0x00
SYN_REPORT = 0
KEY_MUTE = 113
KEY_VOLUMEDOWN = 114
KEY_VOLUMEUP = 115
KEY_F1 = 59
KEY_F2 = 60
KEY_F3 = 61
KEY_F4 = 62
KEY_F5 = 63
KEY_F6 = 64
KEY_F7 = 65
KEY_F8 = 66
KEY_F9 = 67
KEY_F10 = 68
KEY_F11 = 87
KEY_F12 = 88
KEY_KBDILLUMTOGGLE = 228
KEY_BRIGHTNESSDOWN = 224
KEY_BRIGHTNESSUP = 225
KEY_MICMUTE = 248
KEY_RFKILL = 247
KEY_PROG1 = 148
KEY_F15 = 185
KEY_EMOJI_PICKER = 585
KEY_SWITCHVIDEOMODE = 227
KEY_LEFTMETA = 125
KEY_RIGHTMETA = 126
KEY_P = 25

VENDOR_PLAIN_TO_FKEY: dict[int, int] = {
    0xC7: KEY_F4,
    0x10: KEY_F5,
    0x20: KEY_F6,
    0x35: KEY_F7,
    0x9C: KEY_F8,
